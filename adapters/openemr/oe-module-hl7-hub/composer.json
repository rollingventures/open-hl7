{
    "name": "openemr/oe-module-hl7-hub",
    "description": "OpenEMR adapter for the EMR-agnostic HL7 hub: bridges OpenEMR patient events to the hub's canonical model and writes canonical data back via the service layer.",
    "type": "openemr-module",
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Chris Dickman"
        }
    ],
    "autoload": {
        "psr-4": {
            "OpenEMR\\Modules\\Hl7Hub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenEMR\\Modules\\Hl7Hub\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.2",
        "psr/log": "^3.0 || ^2.0 || ^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:integration": "tests/run-integration.sh"
    }
}
